{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "1.8.2",
  "minimum_chrome_version": "116",
  "description": "Scrape job postings from any site and track them on a kanban board.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Job Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/shared/constants.js",
        "src/shared/description-format-core.js",
        "src/content/job-sites.js",
        "src/content/scraper.js",
        "src/content/linkedin-scraper.js",
        "src/content/spa-watcher.js",
        "src/content/preview-panel.js",
        "src/content/highlight.js",
        "src/content/loading-ui.js",
        "src/content/overlay.js",
        "src/content/content.js"
      ],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png", "icons/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
